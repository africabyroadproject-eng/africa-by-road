# MongoDB Connection
# Example: mongodb://localhost:27017/africa-by-road
# For production on Render, use the connection string from your MongoDB addon
MONGODB_URI=mongodb://localhost:27017/africa-by-road

# JWT Secret (generate a strong random string for production)
# Can use: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=dev_secret_key_change_in_production

# Server Port
PORT=3000

# ============================================
# MeCash Payment Integration (Nigeria)
# ============================================
# Get from https://developer.me-cash.com/ or use sandbox below
MECASH_API_KEY=M1atIix8.6TYqlebNUmpSRkcBeQ!ez#eIbpvMa0uhuB7NlT7Xw.O3Q4IH9@2qjBo
MECASH_PUBLIC_KEY=M1atIix8.6TYqlebNUmpSRkcBeQ!ez#eIbpvMa0uhuB7NlT7Xw.O3Q4IH9@2qjBo
MECASH_MODE=sandbox
# Callback URL for payment confirmation
PAYMENT_CALLBACK_URL=https://your-backend.onrender.com/api/payments/callback

# ============================================
# Email Configuration
# ============================================
# For development, emails are logged to console
# In production, configure SendGrid, Mailgun, or AWS SES
SENDGRID_API_KEY=
EMAIL_FROM=your_verified_sender@email.com

# ============================================
# Google OAuth (Optional)
# ============================================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ============================================
# Frontend & CORS
# ============================================
FRONTEND_URL=https://your-frontend.onrender.com

# ============================================
# Logging
# ============================================
NODE_ENV=development
AUDIT_LOG_FILE=audit.log
ERROR_LOG_FILE=error.log