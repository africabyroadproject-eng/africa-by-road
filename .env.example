# MONGODB_URI should be your MongoDB connection string
# Example: mongodb://localhost:27017/africa-by-road
MONGODB_URI=your_mongodb_uri_here

# JWT Secret for token signing (use a strong random string)
JWT_SECRET=your_jwt_secret_here

# PORT (default: 3000)
PORT=3000

# Paystack Payment Integration
# Get your keys from https://dashboard.paystack.com/#/apikey
PAYSTACK_SECRET_KEY=your_paystack_secret_key
PAYSTACK_PUBLIC_KEY=your_paystack_public_key
PAYMENT_CALLBACK_URL=http://localhost:3000/api/payments/callback

# Email Configuration (for sending verification emails)
# Example using SendGrid
SENDGRID_API_KEY=your_sendgrid_api_key
EMAIL_FROM=noreply@africabyroad.com

# Google OAuth (optional)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Frontend URL for CORS and callbacks
FRONTEND_URL=http://localhost:5173